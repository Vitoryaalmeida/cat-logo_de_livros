import java.util.*;
import java.net.*;
import java.io.*;

public class SistemaLivros {

    static class Autor {
        String nome;
        int nascimento;
        int falecimento;
        List<String> livros = new ArrayList<>();

        public Autor(String nome, int nascimento, int falecimento) {
            this.nome = nome;
            this.nascimento = nascimento;
            this.falecimento = falecimento;
        }
    }

    static class Livro {
        String titulo;
        String idioma;
        Autor autor;

        public Livro(String titulo, String idioma, Autor autor) {
            this.titulo = titulo;
            this.idioma = idioma;
            this.autor = autor;
        }
    }

    static List<Livro> livros = new ArrayList<>();
    static List<Autor> autores = new ArrayList<>();

    public static void main(String[] args) throws Exception {

        Scanner scanner = new Scanner(System.in);
        int opcao = -1;

        while (opcao != 0) {

            System.out.println("\n===== MENU =====");
            System.out.println("1 - Buscar livro pelo título");
            System.out.println("2 - Listar livros registrados");
            System.out.println("3 - Listar autores");
            System.out.println("4 - Listar autores vivos em um ano");
            System.out.println("5 - Listar livros por idioma");
            System.out.println("0 - Sair");

            opcao = scanner.nextInt();
            scanner.nextLine();

            switch (opcao) {

                case 1:
                    buscarLivro(scanner);
                    break;

                case 2:
                    listarLivros();
                    break;

                case 3:
                    listarAutores();
                    break;

                case 4:
                    autoresPorAno(scanner);
                    break;

                case 5:
                    livrosPorIdioma(scanner);
                    break;
            }
        }
    }

    public static void buscarLivro(Scanner scanner) throws Exception {

        System.out.println("Digite o título do livro:");
        String titulo = scanner.nextLine();

        String urlString = "https://gutendex.com/books/?search=" + titulo.replace(" ", "%20");

        URL url = new URL(urlString);
        HttpURLConnection conexao = (HttpURLConnection) url.openConnection();
        conexao.setRequestMethod("GET");

        BufferedReader leitor = new BufferedReader(new InputStreamReader(conexao.getInputStream()));
        String linha;
        StringBuilder resposta = new StringBuilder();

        while ((linha = leitor.readLine()) != null) {
            resposta.append(linha);
        }

        leitor.close();

        String json = resposta.toString();

        System.out.println("\nResultado da API:");
        System.out.println(json);

        // Simulação de cadastro
        Autor autor = new Autor("Autor Exemplo", 1900, 1980);
        Livro livro = new Livro(titulo, "en", autor);

        autor.livros.add(titulo);

        autores.add(autor);
        livros.add(livro);

        System.out.println("\nLivro registrado no sistema!");
    }

    public static void listarLivros() {

        System.out.println("\n=== LIVROS REGISTRADOS ===");

        for (Livro l : livros) {
            System.out.println("Título: " + l.titulo);
            System.out.println("Autor: " + l.autor.nome);
            System.out.println("Idioma: " + l.idioma);
            System.out.println("--------------------");
        }
    }

    public static void listarAutores() {

        System.out.println("\n=== AUTORES ===");

        for (Autor a : autores) {
            System.out.println("Autor: " + a.nome);
            System.out.println("Nascimento: " + a.nascimento);
            System.out.println("Falecimento: " + a.falecimento);
            System.out.println("Livros: " + a.livros);
            System.out.println("--------------------");
        }
    }

    public static void autoresPorAno(Scanner scanner) {

        System.out.println("Digite o ano:");
        int ano = scanner.nextInt();

        System.out.println("\nAutores vivos nesse ano:");

        for (Autor a : autores) {

            if (ano >= a.nascimento && ano <= a.falecimento) {
                System.out.println(a.nome);
            }
        }
    }

    public static void livrosPorIdioma(Scanner scanner) {

        System.out.println("Digite o idioma:");
        String idioma = scanner.nextLine();

        System.out.println("\nLivros nesse idioma:");

        for (Livro l : livros) {

            if (l.idioma.equalsIgnoreCase(idioma)) {
                System.out.println(l.titulo + " - " + l.autor.nome);
            }
        }
    }
}
